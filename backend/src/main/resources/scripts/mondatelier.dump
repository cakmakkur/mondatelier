--
-- Name: profiles; Type: TABLE; Schema: public; Owner: mondatelier
--

CREATE TABLE public.profiles (
    id character varying(255) NOT NULL,
    user_id character varying(255),
    profile_type_id integer,
    profile_name character varying(255),
    firstname character varying(255) NOT NULL,
    lastname character varying(255) NOT NULL,
    dob timestamp(6) without time zone NOT NULL,
    bio character varying(255),
    personal_website character varying(255),
    country_id bigint,
    banner_path character varying(255),
    profile_picture_path character varying(255),
    show_real_name boolean DEFAULT false,
    active boolean DEFAULT false
);


ALTER TABLE public.profiles OWNER TO mondatelier;

--
-- Name: user_follows; Type: TABLE; Schema: public; Owner: mondatelier
--

CREATE TABLE public.user_follows (
    follower_id text NOT NULL,
    following_id text NOT NULL,
    followed_at timestamp with time zone DEFAULT CURRENT_TIMESTAMP NOT NULL
);


ALTER TABLE public.user_follows OWNER TO mondatelier;

--
-- Name: user_preferences; Type: TABLE; Schema: public; Owner: mondatelier
--

CREATE TABLE public.user_preferences (
    id bigint NOT NULL,
    language_id bigint DEFAULT 1,
    preferred_city_id bigint,
    animations boolean DEFAULT true,
    preferred_country_id bigint,
    profile_id character varying(255),
    notifications boolean DEFAULT true
);


ALTER TABLE public.user_preferences OWNER TO mondatelier;

